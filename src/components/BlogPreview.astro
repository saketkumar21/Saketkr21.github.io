---
import { site } from '../config';

// Build-time RSS fetch. Attempts to pull latest posts from whiz.pub blog.
// Gracefully falls back to an empty state if:
//   - blogUrl not configured yet
//   - blogRssEnabled is false
//   - fetch fails (whiz.pub not signed up yet, or offline during build)

type Post = { title: string; url: string; date: string; summary: string };
let posts: Post[] = [];
let fetchError: string | null = null;

if (site.urls.blogRssEnabled && site.urls.blogUrl) {
  try {
    const rssUrl = `${site.urls.blogUrl.replace(/\/$/, '')}/rss.xml`;
    const res = await fetch(rssUrl, { headers: { 'User-Agent': 'saketkr21-portfolio-build' } });
    if (res.ok) {
      const xml = await res.text();
      // Minimal RSS 2.0 parser (no dependencies). Extracts <item> blocks.
      const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)].slice(0, 4);
      posts = items.map((m) => {
        const block = m[1];
        const pick = (tag: string) => {
          const re = new RegExp(`<${tag}(?:\\s[^>]*)?>(?:<!\\[CDATA\\[)?([\\s\\S]*?)(?:\\]\\]>)?<\\/${tag}>`);
          const match = block.match(re);
          return match ? match[1].trim() : '';
        };
        return {
          title: pick('title'),
          url: pick('link'),
          date: pick('pubDate'),
          summary: pick('description').replace(/<[^>]+>/g, '').trim().slice(0, 200),
        };
      }).filter((p) => p.title && p.url);
    } else {
      fetchError = `HTTP ${res.status}`;
    }
  } catch (e: any) {
    fetchError = e?.message ?? 'unknown';
  }
}

function fmtDate(s: string): string {
  if (!s) return '';
  try {
    return new Date(s).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  } catch {
    return s;
  }
}

const blogHref = site.urls.blogUrl || 'https://whiz.pub';
---

<section id="blog" class="section">
  <header class="section__header">
    <span class="section__eyebrow">Writing</span>
    <h2 class="section__title">Notes from the field.</h2>
  </header>

  {posts.length > 0 ? (
    <ul class="blog-preview" role="list">
      {posts.map((p) => (
        <a href={p.url} target="_blank" rel="noopener" class="blog-preview__item">
          <span class="blog-preview__date">{fmtDate(p.date)}</span>
          <span class="blog-preview__title">{p.title}</span>
          {p.summary && <span class="blog-preview__summary">{p.summary}…</span>}
        </a>
      ))}
    </ul>
  ) : (
    <div class="blog-preview__empty">
      <p>
        My blog lives at <a href={blogHref} target="_blank" rel="noopener">{site.urls.blogUrl || 'whiz.pub'}</a> — powered by
        <a href="https://whiz.pub" target="_blank" rel="noopener">whiz.pub</a>.
        {!site.urls.blogUrl && (
          <><br /><small style="opacity:0.7">Once you configure <code>site.urls.blogUrl</code> in <code>src/config.ts</code> and enable RSS fetch, latest posts render inline here.</small></>
        )}
      </p>
    </div>
  )}

  <div style="margin-top:24px;">
    <a href={blogHref} target="_blank" rel="noopener" class="link link--arrow">Read all posts on {site.urls.blogUrl ? new URL(site.urls.blogUrl).hostname : 'whiz.pub'} →</a>
  </div>
</section>
